    -unity-font-definition: url("project://database/Assets/Sprites/minecraft/Minecraft.ttf?fileID=12800000&guid=4556de84cb5c3cc4d8a26ae9ef1f2788&type=3#Minecraft");
    font-size: 12px;
    background-color: rgb(213, 66, 66);
}

.buttons-victory {
    position: absolute;
    height: 30px;
    width: 300px;
    top: 230px;
    flex-direction: row;
    justify-content: center;
    -unity-text-align: upper-center;
    align-self: center;
    align-items: center;
    align-content: center;
}

.menu-button {
