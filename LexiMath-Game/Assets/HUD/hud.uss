.coins-container {
    position: absolute;
    top: 50px;
    left: 30px;
    width: 120px;
    height: 25px;
    justify-content: center;
    align-self: center;
}

.coin-image {
    left: 0;
    width: 20px;
    height: 20px;
    background-color: rgba(0, 0, 0, 0);
    background-image: url("project://database/Assets/Sprites/coins-chests-etc-2-0.png?fileID=712486646&guid=1d1f04dc0919b5141acd9e66f928432e&type=3#coins-chests-etc-2-0_54");
}

.contador-texto {
    -unity-font-definition: url("project://database/Assets/Sprites/minecraft/Minecraft.ttf?fileID=12800000&guid=4556de84cb5c3cc4d8a26ae9ef1f2788&type=3#Minecraft");
    color: rgb(255, 165, 0);
    font-size: 15px;
    position: absolute;
    left: 20px;
    top: 0;
    align-self: center;
    justify-content: center;
    align-items: center;
}

.victory-panel {
    position: absolute;
    background-color: rgba(0, 0, 0, 0.51);
    align-self: center;
    align-items: center;
    align-content: center;
    justify-content: center;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: none;
}

.mapVictory {
    align-self: center;
    justify-content: center;
    align-items: center;
    align-content: center;
