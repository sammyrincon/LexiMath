    background-image: url("project://database/Assets/Sprites/coins-chests-etc-2-0.png?fileID=1113886084&guid=1d1f04dc0919b5141acd9e66f928432e&type=3#coins-chests-etc-2-0_459");
}

.star3 {
    width: 35px;
