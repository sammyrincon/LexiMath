    top: -8px;
    left: 170px;
    background-image: url("project://database/Assets/Sprites/coins-chests-etc-2-0.png?fileID=-1848202386&guid=1d1f04dc0919b5141acd9e66f928432e&type=3#coins-chests-etc-2-0_457");
}

.points-text {
    position: absolute;
    top: 50px;
    align-items: center;
    justify-content: center;
    align-self: center;
    align-content: center;
    -unity-font-definition: url("project://database/Assets/Sprites/minecraft/Minecraft.ttf?fileID=12800000&guid=4556de84cb5c3cc4d8a26ae9ef1f2788&type=3#Minecraft");
    font-size: 15px;
    left: auto;
}

.points-number {
    top: 175px;
    -unity-font-definition: url("project://database/Assets/Sprites/minecraft/Minecraft.ttf?fileID=12800000&guid=4556de84cb5c3cc4d8a26ae9ef1f2788&type=3#Minecraft");
